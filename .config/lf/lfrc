set previewer sixel

# # Basic Settings
 set hidden true
 set ignorecase true

# # Custom Functions
 cmd mkdir ${{
   printf "Directory Name: "
   read ans
   mkdir $ans
 }}

 cmd mkfile ${{
   printf "File Name: "
   read ans
   $EDITOR $ans
 }}


 # Archive bindings
 cmd unarchive ${{
   case "$f" in
       *.zip) unzip "$f" ;;
       *.tar.gz) tar -xzvf "$f" ;;
       *.tar.bz2) tar -xjvf "$f" ;;
       *.tar) tar -xvf "$f" ;;
       *) echo "Unsupported format" ;;
   esac
 }}

# # Bindings
 map c $vscodium "$f"
 map au unarchive

# # Basic Functions
 map . set hidden!
 map p paste
 map x cut
 map y copy
 map <enter> open
 map R reload
 map mf mkfile
 map md mkdir
 map C clear

# # Novement
 map gD cd ~/Documents
 map gd cd ~/Downloads
 map gp cd ~/Pictures
 map gc cd ~/.config
 map gv cd ~/Videos
